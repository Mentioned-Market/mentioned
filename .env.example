# Mentioned — Next.js app environment.
#
# Copy this file to `.env.local` and fill in real values:
#   cp .env.example .env.local
#
# `.env.local` is gitignored — never commit it.
#
# The transcript-worker service has its own env scope and its own .env.example
# at services/transcript-worker/.env.example. The two share DATABASE_URL.

# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — app won't boot without these
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection string. The full app + transcript worker share one DB.
# Local docker (see `npm run db:start`): postgresql://mentioned:mentioned@localhost:5432/mentioned
# Production: copy from Railway → Postgres → Connect tab.
DATABASE_URL=postgresql://mentioned:mentioned@localhost:5432/mentioned

# Set 'false' for local docker. Leave unset (or anything else) for managed
# Postgres providers that require TLS (Railway, Supabase, Neon, etc.).
DB_SSL=false

# Solana mainnet RPC via Helius. Used server-side for all on-chain reads
# and writes. Get an API key from https://helius.dev.
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=

# Same URL but client-exposed (the browser hits it for wallet ops). Usually
# identical to HELIUS_RPC_URL above.
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=

# Devnet RPC for the on-chain USDC AMM (the program is deployed on devnet).
# Different API key recommended to keep credit usage separable.
NEXT_PUBLIC_HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=

# Privy embedded-wallet provider. Sign up at https://privy.io.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Random string used to sign auth session cookies. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Jupiter Prediction API key (Polymarket integration). Required for any
# /polymarkets/* route to function. Apply at https://docs.jup.ag.
JUPITER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────────────────────────────────────

# Comma-separated Solana pubkeys with admin privileges (market creation,
# resolution, transcription controls, etc.). lib/adminAuth.ts gates routes
# on membership in this list.
ADMIN_WALLETS=

# ─────────────────────────────────────────────────────────────────────────
# DISCORD OAUTH — required for linking, gates free-market trading + points
# ─────────────────────────────────────────────────────────────────────────
#
# Create an application at https://discord.com/developers/applications.
# Set the redirect URI in the OAuth2 panel to match DISCORD_REDIRECT_URI.

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/discord/callback

# Random string used to sign the OAuth state parameter (CSRF protection).
# Generate with: openssl rand -base64 32
DISCORD_STATE_SECRET=

# Bot token used to assign the "verified" role on link. The bot must be in
# DISCORD_GUILD_ID with permission to manage that role.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VERIFIED_ROLE_ID=

# ─────────────────────────────────────────────────────────────────────────
# DISCORD WEBHOOKS — notifications (optional but recommended)
# ─────────────────────────────────────────────────────────────────────────

# Bug-report form posts here. Without it, the bug-report API skips the
# Discord post and just records the submission to DB.
DISCORD_BUG_REPORT_WEBHOOK_URL=

# Posted to when an admin creates a new free or paid market.
DISCORD_NEW_MARKET_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────
# HELIUS WEBHOOK — trade indexer
# ─────────────────────────────────────────────────────────────────────────

# Shared secret Helius includes in the Authorization header. /api/webhook
# rejects payloads that don't match. Set the same value in your Helius
# webhook config.
HELIUS_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────

# Absolute base URL of the app — used in OG image URLs, share links, and
# referral redirects. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

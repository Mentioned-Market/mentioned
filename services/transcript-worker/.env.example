# transcript-worker config.
#
# Copy this file to `.env` (in the same directory) and fill in real values.
# `.env` is gitignored — never commit it. The worker auto-loads `.env` via
# dotenv on startup, so once it's in place you don't need to set env vars
# in the shell.
#
# On Windows: rename to .env (no .txt extension!), edit in any text editor.
# On macOS/Linux: `cp .env.example .env`, then edit.

# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — won't boot without these
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection string. Same DB as the Next.js app.
# Production:  copy from Railway → Postgres service → "Connect" tab.
# Local docker: postgres://postgres:postgres@localhost:5432/mentioned
DATABASE_URL=

# 'require' if your DB uses TLS (Railway, Supabase, most managed). Leave blank
# for local Docker. The worker also detects sslmode=require in DATABASE_URL.
PGSSL=require

# Deepgram API key (PAYG account; Nova-3 streaming). Without this the worker
# refuses to spawn StreamWorkers — but it'll still boot and listen.
DEEPGRAM_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# WORKER POOL
# ─────────────────────────────────────────────────────────────────────────

# 'cloud' (default) is the standard deploy — handles twitch:// and youtube://
# URLs end-to-end. Workers only claim monitored_streams rows whose worker_pool
# matches. Leave this alone unless you specifically need to capture audio
# from a local device for development.
WORKER_POOL=cloud

# Local-audio capture, only needed when WORKER_POOL=local. Lets the worker
# read from a system audio device instead of a remote stream URL — useful
# for development against a known audio file or a virtual cable.
# Run `ffmpeg -f avfoundation -list_devices true -i ""` (macOS) or
# `ffmpeg -list_devices true -f dshow -i dummy` (Windows) to discover device
# names, then match byte-for-byte.
LOCAL_AUDIO_FORMAT=
LOCAL_AUDIO_DEVICE=

# ─────────────────────────────────────────────────────────────────────────
# DISCORD + URLS
# ─────────────────────────────────────────────────────────────────────────

# Reuses the existing bug-report webhook. Without it, summaries and
# first-mention pings log "skipped" and post nothing.
DISCORD_WEBHOOK_URL=

# Override for the "Resolve:" link in Discord summaries. If unset:
#   ENVIRONMENT=staging  → https://mentioned-staging.up.railway.app
#   anything else        → https://mentioned.market
# APP_BASE_URL=

# Used for the APP_BASE_URL fallback above. The Next.js side already sets
# this in production / staging — match what's there.
ENVIRONMENT=production

# ─────────────────────────────────────────────────────────────────────────
# COST / RUNTIME LIMITS — defaults are fine for most use
# ─────────────────────────────────────────────────────────────────────────

# Max concurrent streams per worker process.
MAX_CONCURRENT_STREAMS=20

# Per-stream hard cap. Stream is force-ended after this many hours regardless
# of any other signal. Runaway protection.
MAX_HOURS_PER_STREAM=12

# Force-end if no finalized transcript segment in this many minutes (ad pods,
# tech difficulties, broadcaster cut feed without clean playlist termination).
MAX_SILENT_MINUTES=20

# Pre-audio hard timeout. The fetcher (streamlink / yt-dlp) is started with
# infinite-retry flags so it waits for a scheduled or running-late streamer
# to go live — cheaply, because we defer opening Deepgram until the first
# PCM byte arrives, so $0 is spent during the wait. This is the upper bound
# on how long that wait can last; if the streamer never shows up, the row
# lands as status='error' with reason='never_started'. Default 120 (2h)
# covers most "streamer is late" cases comfortably.
SCHEDULED_STREAM_WAIT_MINUTES=120

# Proactively rotate the Deepgram WS this often. Smooths over transient
# network blips and provider-side maintenance windows.
DEEPGRAM_ROTATE_MINUTES=90

# Proactively recycle the ffmpeg process this often. Avoids slow memory
# creep on multi-hour streams.
FFMPEG_RECYCLE_MINUTES=240

# Cost watchdog — daily cents (USD × 100). Computed against today's UTC
# monitored_streams.cost_cents sum.
#   ALERT: post a Discord warning when crossed. Streams continue.
#   HALT:  refuse new spawns when crossed. Existing streams continue.
DAILY_COST_CENTS_ALERT=2000
DAILY_COST_CENTS_HALT=5000

# ─────────────────────────────────────────────────────────────────────────
# AUDIO CLIP CAPTURE (optional)
# ─────────────────────────────────────────────────────────────────────────
#
# Captures a short WAV clip of the audio surrounding each detected mention and
# stores it in an S3-compatible bucket, allowing administrators to review the
# audio before resolving a market. Active only when CLIP_CAPTURE_ENABLED=true
# and the S3 credentials below are provided; when disabled it adds no memory or
# processing overhead. The web application reads the same credentials to serve
# clips through presigned URLs.
CLIP_CAPTURE_ENABLED=false

# Duration of audio (in seconds) retained in memory per stream, at roughly
# 32 KB/s. Should comfortably exceed CLIP_PAD_SECONDS plus CLIP_TRAILING_DELAY_MS;
# the default provides ample margin.
CLIP_BUFFER_SECONDS=60

# Padding (in seconds) included on either side of a mention's transcript segment.
CLIP_PAD_SECONDS=3

# Delay (in milliseconds) before a clip is extracted. Deepgram returns finalized
# transcripts approximately 1–2 seconds after the corresponding audio, so this
# brief wait ensures the trailing context is buffered before extraction.
CLIP_TRAILING_DELAY_MS=3500

# Private S3-compatible bucket used for clip storage. Supply the values from your
# storage provider's credentials; on Railway, reference the bucket's Credentials
# tab. The endpoint is provided by the bucket and varies between deployments. The
# AWS_* variable names follow the S3 client's standard convention and apply to any
# S3-compatible provider. Clips are accessible only through presigned URLs.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Endpoint addressing style. Leave false for virtual-hosted-style URLs, the
# default for most providers including Railway. Set true only if your bucket
# requires path-style addressing.
S3_FORCE_PATH_STYLE=false

# ─────────────────────────────────────────────────────────────────────────
# OPS
# ─────────────────────────────────────────────────────────────────────────

# 'debug' surfaces fetcher / ffmpeg stderr line-by-line. 'info' is fine for
# normal operation; non-zero exits already include a stderr tail at warn level.
LOG_LEVEL=info

# HTTP port for /health. Railway sets this automatically; local dev can leave it.
PORT=3001

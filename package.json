{
  "name": "mentioned",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:start": "docker compose up -d && docker compose exec db sh -c 'until pg_isready -U mentioned; do sleep 1; done' && npm run db:migrate && npm run db:seed",
    "db:migrate": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/migrate.ts",
    "db:seed": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed.ts dotenv_config_path=.env.local",
    "db:stop": "docker compose down",
    "db:leaderboard-test:seed": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-leaderboard-test.ts dotenv_config_path=.env.local",
    "db:leaderboard-test:clean": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-leaderboard-test-clean.ts dotenv_config_path=.env.local",
    "db:seed-staging": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-staging.ts",
    "market:image": "npx ts-node -r dotenv/config --project tsconfig.scripts.json scripts/generate-market-image.ts",
    "market:simulate": "npx ts-node --project tsconfig.scripts.json scripts/simulate-trades.ts"
  },
  "dependencies": {
    "@2toad/profanity": "^3.3.0",
    "@farcaster/mini-app-solana": "^1.1.3",
    "@privy-io/react-auth": "^3.18.0",
    "@privy-io/server-auth": "^1.32.5",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.0.1",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@wallet-standard/app": "^1.1.0",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "lightweight-charts": "^4.2.3",
    "next": "^14.0.0",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.0",
    "tweetnacl": "^1.0.3"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^3.3.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
